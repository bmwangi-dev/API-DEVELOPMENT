API_PORT=8000
API_CONTAINER_PORT=8000
API_CONTAINER_NAME=habittracker-api
API_RELOAD=true

POSTGRES_DB=habittracker
POSTGRES_USER=habittracker
POSTGRES_PASSWORD=change-me-in-real-projects
POSTGRES_PORT=5433
POSTGRES_CONTAINER_PORT=5432
POSTGRES_HOST=db
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_CONTAINER_NAME=habittracker-postgres
POSTGRES_DATA_DIR=/var/lib/postgresql/data

SECRET_KEY=replace-with-a-long-random-secret

RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_HOST=rustfs
RUSTFS_CONTAINER_PORT=9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=habitapp
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_CONSOLE_CONTAINER_PORT=9001
RUSTFS_BIND_HOST=0.0.0.0
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_DATA_DIR=/data
RUSTFS_IMAGE=rustfs/rustfs:latest
RUSTFS_CONTAINER_NAME=habittracker-rustfs
RUSTFS_ALIAS=rustfs
RUSTFS_INIT_IMAGE=minio/mc:latest
RUSTFS_INIT_CONTAINER_NAME=habittracker-rustfs-init
